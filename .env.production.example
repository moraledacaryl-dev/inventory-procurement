APP_ENV=production
APP_NAME=Hidden Oasis Inventory & Procurement
API_V1_PREFIX=/api/v1

POSTGRES_DB=inventory
POSTGRES_USER=inventory
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://inventory:REPLACE_WITH_A_LONG_RANDOM_DATABASE_PASSWORD@db:5432/inventory

JWT_SECRET=REPLACE_WITH_AT_LEAST_64_RANDOM_CHARACTERS
ACCESS_TOKEN_MINUTES=480
CORS_ORIGINS=["https://inventory.hiddenoasis.app"]
TRUSTED_HOSTS=["inventory.hiddenoasis.app"]
MAX_REQUEST_BYTES=10485760
BACKUP_MAX_AGE_HOURS=48

BOOTSTRAP_OWNER_EMAIL=REPLACE_WITH_YOUR_OWNER_EMAIL
BOOTSTRAP_OWNER_NAME=Caryl Moraleda
BOOTSTRAP_OWNER_PASSWORD=REPLACE_WITH_A_LONG_UNIQUE_OWNER_PASSWORD

BACKUP_DIR=/backups
INTEGRATION_ENDPOINTS_JSON={}
