APP_ENV=development
APP_NAME=Hidden Oasis Inventory & Procurement
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://inventory:inventory@db:5432/inventory
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_MINUTES=480
CORS_ORIGINS=http://localhost:3000
BOOTSTRAP_OWNER_EMAIL=owner@hiddenoasis.local
BOOTSTRAP_OWNER_NAME=Owner
BOOTSTRAP_OWNER_PASSWORD=change-this-password-now
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
INTEGRATION_ENDPOINTS_JSON={"accounting":"http://accounting-api:8000/api/v1/integration-events","pos":"http://pos-api:8000/api/v1/integration-events","command-center":"http://command-center-api:8000/api/v1/integration-events","staff":"http://staff-api:8000/api/v1/integration-events"}
