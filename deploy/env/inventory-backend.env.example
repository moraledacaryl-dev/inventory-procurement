APP_ENV=production
APP_NAME=Hidden Oasis Inventory & Procurement
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://hiddenoasis_inventory_app:REPLACE_WITH_DATABASE_PASSWORD@127.0.0.1:5432/hiddenoasis_inventory_live
JWT_SECRET=REPLACE_WITH_AT_LEAST_64_RANDOM_CHARACTERS
ACCESS_TOKEN_MINUTES=480
CORS_ORIGINS=["https://inventory.hiddenoasis.app"]
TRUSTED_HOSTS=["inventory.hiddenoasis.app"]
MAX_REQUEST_BYTES=10485760
BACKUP_MAX_AGE_HOURS=48
BOOTSTRAP_OWNER_EMAIL=REPLACE_WITH_OWNER_EMAIL
BOOTSTRAP_OWNER_NAME=Caryl Moraleda
BOOTSTRAP_OWNER_PASSWORD=REPLACE_WITH_LONG_OWNER_PASSWORD
BACKUP_DIR=/var/backups/hiddenoasis/inventory
INTEGRATION_ENDPOINTS_JSON={}
